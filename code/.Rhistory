labs(x = NULL,
y = NULL,
color = NULL,
fill = NULL,
subtitle = str_glue("{z}")) +
theme(panel.grid.major.y = element_line(color = "grey80"),
legend.direction = "horizontal",
legend.position = "bottom",
axis.text.y = element_blank(),
plot.margin = margin(t = 2, r = 7, b = 2, l = 2, unit = "mm"))
}
plot_list[[z_index]] <- p
z_index <- z_index + 1
}
ggarrange(plotlist = plot_list,
nrow = 2, ncol = 4,
align = "hv",
common.legend = TRUE,
