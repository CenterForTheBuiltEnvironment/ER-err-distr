# all scenarios at hourly resolution at 2050
avg_annot <- df_annual %>%
filter(gea == gea_example,
year %in% c(2025, 2050),
scenario %in% c("MidCase", "LowRECost_HighNGPrice")) %>%
mutate(x_pos = if_else(year == 2025, as.POSIXct("2026-01-15 00:00:00"), as.POSIXct("2051-01-15 00:00:00")))
